background-opacity = 0.9
# Kitty default color palette
palette = 0=#000000
palette = 1=#cc0403
palette = 2=#19cb00
palette = 3=#cecb00
palette = 4=#0d73cc
palette = 5=#cb1ed1
palette = 6=#0dcdcd
palette = 7=#dddddd
palette = 8=#767676
palette = 9=#f2201f
palette = 10=#23fd00
palette = 11=#fffd00
palette = 12=#1a8fff
palette = 13=#fd28ff
palette = 14=#14ffff
palette = 15=#ffffff

foreground = #dddddd
background = #000000

font-family = JetBrainsMono Nerd Font
font-size = 18
adjust-cell-height = 10%

# Appearance
background-opacity = 0.8
background = #000000
background-blur-radius = 60
window-decoration = false
window-theme = dark
cursor-style = bar

# Tabs at bottom, smaller size (like kitty powerline tabs)
gtk-tabs-location = bottom
gtk-custom-css = tab { padding: 2px 8px; font-size: 0.85em; min-height: 0; } window { border-radius: 20px; }

# Terminal behavior
confirm-close-surface = false
scrollback-limit = 2000
mouse-hide-while-typing = true
bold-is-bright = true
shell-integration = detect
shell-integration-features = cursor,sudo
term = xterm-256color



# Keybinds — Super+B leader (matching kitty config)
# Tab management
keybind = super+b>c=new_tab
keybind = super+b>x=close_surface
keybind = super+b>one=goto_tab:1
keybind = super+b>two=goto_tab:2
keybind = super+b>three=goto_tab:3
keybind = super+b>four=goto_tab:4
keybind = super+b>five=goto_tab:5
keybind = super+b>six=goto_tab:6
keybind = super+b>seven=goto_tab:7
keybind = super+b>eight=goto_tab:8
keybind = super+b>nine=goto_tab:9
keybind = super+b>n=new_window

# Splits (matching kitty: \ for vsplit, - for hsplit)
keybind = super+b>backslash=new_split:right
keybind = super+b>minus=new_split:down

# Split navigation (vim-style hjkl)
keybind = super+h=goto_split:left
keybind = super+j=goto_split:bottom
keybind = super+k=goto_split:top
keybind = super+l=goto_split:right

